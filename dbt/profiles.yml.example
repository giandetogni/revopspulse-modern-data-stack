revopspulse:
  target: dev
  outputs:
    dev:
      type: postgres
      host: "{{ env_var('POSTGRES_HOST', 'postgres') }}"
      user: "{{ env_var('POSTGRES_USER', 'revopspulse') }}"
      password: "{{ env_var('POSTGRES_PASSWORD', 'revopspulse') }}"
      port: "{{ env_var('POSTGRES_PORT', 5432) | int }}"
      dbname: "{{ env_var('POSTGRES_DB', 'revopspulse') }}"
      schema: analytics
      threads: 4
